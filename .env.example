# Frontend (Expo) environment.
# Copy this file to .env and fill in values for your machine.

# Your laptop's LAN IP (run `ipconfig` → look under "Wireless LAN adapter Wi-Fi").
# - Real phone via Expo Go: use the LAN IP, e.g. http://192.168.1.23:4000/api
# - Android emulator       : http://10.0.2.2:4000/api
# - iOS simulator / web    : http://localhost:4000/api
EXPO_PUBLIC_API_URL=http://YOUR-LAPTOP-LAN-IP:4000/api

# Same Supabase project as the backend
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
